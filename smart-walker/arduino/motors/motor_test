//Test left motor
const int ENA = 5;
const int IN1 = 7;
const int IN2 = 8;

void setup() {
  pinMode(ENA, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);

  // set direction forward
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
}

void loop() {
  analogWrite(ENA, 200); // spin
  delay(2000);

  analogWrite(ENA, 0);   // stop
  delay(2000);
}



